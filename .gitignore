# =============================================
# BaxtiyorAiTest - Git Ignore
# =============================================

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual Environment
venv/
env/
ENV/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# Database
*.db
*.sqlite3
instance/
migrations/versions/*  # Keep the migrations folder but ignore generated versions if needed

# Environment Variables
.env
.flaskenv

# Uploads & Media
uploads/*
!uploads/.gitkeep

# Logs & Backups
logs/*
!logs/.gitkeep
backups/*
*.log

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Testing & Coverage
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/

# Production & Deployment
*.pid
*.dump
*.bak
*.tmp

# Optional
node_modules/
static/dist/