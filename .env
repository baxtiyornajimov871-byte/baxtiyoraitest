# =============================================
# BaxtiyorAiTest - Environment Configuration
# =============================================

# Flask Settings
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=BaxtiyorAiTest-2026-ultra-secure-key-please-change-in-production-512bit-random

# JWT Settings
JWT_SECRET_KEY=BaxtiyorAiTest-jwt-2026-super-secret-change-this-immediately
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Database
DATABASE_URL=sqlite:///instance/baxtiyoraidb.db
# Production PostgreSQL Example:
# DATABASE_URL=postgresql://baxtiyor:strongpassword@localhost:5432/baxtiyoraidb

# AI Providers API Keys
GROQ_API_KEY=gsk_your_actual_groq_api_key_here
HUGGINGFACE_API_KEY=hf_your_actual_huggingface_token_here

# Application Settings
APP_NAME=BaxtiyorAiTest
VERSION=1.0.0
UPLOAD_FOLDER=uploads
MAX_UPLOAD_SIZE=52428800

# Security
BCRYPT_LOG_ROUNDS=12
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Rate Limiting
RATELIMIT_DEFAULT=200 per day
RATELIMIT_AUTH=10 per minute

# Logging
LOG_LEVEL=INFO

# Optional Future Settings
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2